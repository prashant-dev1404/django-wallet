# .env.example
#
# Copy to .env (gitignored) and fill in real values for local dev.
#
# DJANGO_SECRET_KEY=replace-me-with-django-generated-key
# DJANGO_DEBUG=True
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# DATABASE_URL=postgres://playto:playto@localhost:5432/playto
# CORS_ALLOWED_ORIGINS=http://localhost:5173
#
# In production (Railway), set these via the Railway dashboard:
#   DJANGO_SECRET_KEY (long random string)
#   DJANGO_DEBUG=False
#   DJANGO_ALLOWED_HOSTS=your-app.up.railway.app
#   DATABASE_URL provided automatically by the Postgres addon
#   CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
